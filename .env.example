# The apex domain you own. In local dev, leave as "localhost".
# In production, set to "dnspreviewer.com".
ROOT_DOMAIN=localhost

# Default preview session lifetime, in minutes. Logged-in users can opt for
# no-expiry links, which ignore this.
SESSION_TTL_MINUTES=15

# Max anonymous preview sessions an IP can create per hour. Logged-in users
# have a much higher ceiling.
RATE_LIMIT_PER_HOUR=10

# Optional comma-separated list of target hostnames to block (abuse prevention).
# Example: BLOCKED_HOSTS=mybank.com,paypal.com
BLOCKED_HOSTS=

# Max response body size to buffer for HTML rewriting, in MB.
# Larger responses are streamed through without rewriting.
MAX_REWRITE_MB=4

# Secret for signing auth session cookies and preview unlock cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-random-64-char-hex-string

# Path to the SQLite database file. In production, put it on a persistent
# volume so it survives redeploys.
DATABASE_PATH=./data/dnspreviewer.db
